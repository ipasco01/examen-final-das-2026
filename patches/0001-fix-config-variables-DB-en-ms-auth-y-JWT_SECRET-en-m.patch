From 0085248281bd467de67f54bf431e39a886bb5d0a Mon Sep 17 00:00:00 2001
From: manuel5717p <ariasvillanuevam14@gmail.com>
Date: Sun, 19 Jul 2026 13:44:38 -0500
Subject: [PATCH 1/3] fix(config): variables DB en ms-auth y JWT_SECRET en
 ms-usuarios/ms-agenda

---
 docker-compose.yml | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/docker-compose.yml b/docker-compose.yml
index 8253dab..261b489 100644
--- a/docker-compose.yml
+++ b/docker-compose.yml
@@ -11,6 +11,12 @@ services:
       - JWT_SECRET=${JWT_SECRET:?Definí JWT_SECRET en tu .env raíz}
       - JWT_EXPIRES_IN=1h
       - SERVICE_NAME=MS_Auth
+      # VARIABLES PARA LA BD (faltaban)
+      - DB_HOST=db-auth
+      - DB_PORT=5432
+      - DB_USER=user_auth
+      - DB_PASSWORD=${AUTH_DB_PASSWORD:?Definí AUTH_DB_PASSWORD en tu .env raíz}
+      - DB_NAME=db_auth
 
   # --- Servicio de Usuarios ---
   ms-usuarios:
@@ -27,6 +33,8 @@ services:
       - DB_NAME=db_usuarios
       - SERVICE_NAME=MS_Usuarios
       - RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER:-rabbit}:${RABBITMQ_DEFAULT_PASS:-rabbit}@rabbitmq:5672
+      # Necesario para validar los JWT emitidos por ms-auth (mismo secreto)
+      - JWT_SECRET=${JWT_SECRET:?Definí JWT_SECRET en tu .env raíz}
     depends_on:
       # Asegura que la BD inicie antes que el servicio
       - db-usuarios
@@ -47,6 +55,8 @@ services:
       - DB_NAME=db_agenda
       - SERVICE_NAME=MS_Agenda
       - RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER:-rabbit}:${RABBITMQ_DEFAULT_PASS:-rabbit}@rabbitmq:5672
+      # Necesario para validar los JWT emitidos por ms-auth (mismo secreto)
+      - JWT_SECRET=${JWT_SECRET:?Definí JWT_SECRET en tu .env raíz}
     depends_on:
       # Depende de su propia BD
       - db-agenda
-- 
