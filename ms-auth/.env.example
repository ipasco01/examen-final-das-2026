# ms-auth/.env.example
PORT=4000

# Configuración de JWT
# IMPORTANTE: En producción, este debe ser un secreto largo, complejo y aleatorio.
# Debe coincidir con el secreto usado por ms-usuarios, ms-agenda y ms-tutorias.
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_EXPIRES_IN=1h

# --- Base de Datos ---
DB_HOST=localhost # Usamos localhost para desarrollo local sin Docker
DB_PORT=5435
DB_USER=user_auth
DB_PASSWORD=password_auth
DB_NAME=db_auth