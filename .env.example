# .env.example (raíz del repo)
# Copiar a .env y completar antes de "docker compose up". Ninguna de estas
# variables tiene valor por defecto en docker-compose.yml: si falta alguna,
# Docker Compose se niega a levantar el servicio que la necesita.
# NUNCA commitear el .env real (ya está en .gitignore).

# --- JWT (compartido por ms-auth, ms-usuarios, ms-agenda, ms-tutorias) ---
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=cambia-este-usuario
RABBITMQ_DEFAULT_PASS=cambia-esta-password

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=cambia-esta-password

# --- Contraseñas de las 4 bases de datos (una por servicio) ---
AUTH_DB_PASSWORD=cambia-esta-password
USUARIOS_DB_PASSWORD=cambia-esta-password
AGENDA_DB_PASSWORD=cambia-esta-password
TUTORIAS_DB_PASSWORD=cambia-esta-password
# Equipo 5 (19/07): ms-notificaciones incorporo su propia base para el log de envios.
NOTIFICACIONES_DB_PASSWORD=cambia-esta-password
