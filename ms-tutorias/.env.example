# ms-tutorias/.env.example
PORT=3000

# Configuración de Logging
LOG_LEVEL=info
SERVICE_NAME=MS_Tutorias

# URLs de los servicios dependientes
MS_USUARIOS_URL=http://localhost:3001/usuarios
MS_AGENDA_URL=http://localhost:3002/agenda
MS_NOTIFICACIONES_URL=http://localhost:3003/notificaciones

# --- RabbitMQ ---
RABBITMQ_URL=amqp://localhost:5672

# --- Base de Datos ---
DB_HOST=localhost # Usamos localhost para desarrollo local sin Docker
DB_PORT=5434
DB_USER=user_tutorias
DB_PASSWORD=password_tutorias
DB_NAME=db_tutorias
DB_STATEMENT_TIMEOUT_MS=5000
DB_CONNECTION_TIMEOUT_MS=5000
DB_POOL_MAX=15
DB_WORKER_POOL_MAX=3

# --- Timeout global de la Saga (S1) ---
SAGA_TIMEOUT_MS=15000

# --- Patrón Outbox de notificaciones (D2) ---
OUTBOX_POLL_INTERVAL_MS=3000
OUTBOX_MAX_INTENTOS=5
OUTBOX_BATCH_LIMIT=20

# --- Worker de compensación de agenda pendiente (D6) ---
COMPENSACION_PENDIENTE_POLL_INTERVAL_MS=5000
COMPENSACION_PENDIENTE_MAX_INTENTOS=3
COMPENSACION_PENDIENTE_BATCH_LIMIT=20

# --- Worker de reconciliación de tutorías PENDIENTE huérfanas (S2) ---
RECONCILIACION_PENDIENTE_UMBRAL_MS=300000
RECONCILIACION_POLL_INTERVAL_MS=60000
RECONCILIACION_BATCH_LIMIT=20