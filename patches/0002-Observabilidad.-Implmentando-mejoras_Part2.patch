diff --git a/ms-auth/src/api/middlewares/correlationId.middleware.js b/ms-auth/src/api/middlewares/correlationId.middleware.js
new file mode 100644
index 0000000..5a85236
--- /dev/null
+++ b/ms-auth/src/api/middlewares/correlationId.middleware.js
@@ -0,0 +1,10 @@
+const { randomUUID } = require('crypto');
+
+const correlationIdMiddleware = (req, res, next) => {
+    const correlationId = req.header('X-Correlation-ID') || randomUUID();
+    req.correlationId = correlationId;
+    res.setHeader('X-Correlation-ID', correlationId);
+    next();
+};
+
+module.exports = correlationIdMiddleware;
\ No newline at end of file
