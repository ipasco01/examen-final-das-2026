{
  "id": null,
  "uid": "tutorias-red-metrics",
  "title": "Tutorías App — Observabilidad (RED + Negocio + Logs)",
  "tags": [
    "tutorias",
    "observabilidad",
    "examen-final"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "RED Metrics — Rate / Errors / Duration por servicio",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Rate — Requests por segundo (por servicio)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(http_request_duration_seconds_count[1m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Errors — % de respuestas 5xx (por servicio)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[1m])) by (service_name) / sum(rate(http_request_duration_seconds_count[1m])) by (service_name) * 100",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Duration — Latencia p95 (por servicio)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, service_name))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 101,
      "title": "Estado de los servicios",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "Servicios activos (up)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "up{service_name!=\"\"}",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CAÍDO",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 102,
      "title": "Circuit Breakers (ms-tutorias → ms-agenda / ms-usuarios)",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "Estado del Circuit Breaker por servicio dependiente",
      "type": "state-timeline",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "circuit_breaker_state",
          "legendFormat": "{{target_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CERRADO",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0.5": {
                  "text": "HALF-OPEN",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ABIERTO",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "always",
        "mergeValues": true
      }
    },
    {
      "id": 103,
      "title": "Logs por microservicio",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "title": "Logs — ms-auth",
      "type": "logs",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "{service=\"ms-auth\"}",
